{
    "name": "ts-sha256",
    "version": "0.1.0",
    "description": "Zero-dependency synchronous SHA-256 for TypeScript",
    "author": "Your Name <dev@xlsft.ru>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/xlsft/ts-sha256.git"
    },
    "bugs": "https://github.com/xlsft/ts-sha256/issues",
    "homepage": "https://github.com/xlsft/ts-sha256#readme",
    "keywords": [
        "sha256",
        "hash",
        "crypto",
        "typescript",
        "zero-dependency"
    ],
    "type": "module",
    "main": "./dist/main.js",
    "module": "./dist/main.js",
    "types": "./dist/main.d.ts",
    "exports": {
        ".": {
            "types": "./dist/main.d.ts",
            "import": "./dist/main.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "test": "bun test",
        "prepublishOnly": "bun run test --timeout 30000 && bun run build",
        "publish": "bun run prepublishOnly && npm version patch && npm publish",
        "publish:patch": "bun run prepublishOnly && npm version patch && npm publish",
        "publish:minor": "bun run prepublishOnly && npm version minor && npm publish",
        "publish:major": "bun run prepublishOnly && npm version major && npm publish"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "typescript": "^5.4.0"
    }
}
